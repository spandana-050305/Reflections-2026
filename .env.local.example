# ── Local mode ───────────────────────────────────────────────
# true  = run fully offline with the file-backed mock store (default for demos)
# false = use the real Supabase cloud (also uncomment the client blocks in
#         src/lib/supabase.ts and src/lib/supabase-server.ts)
NEXT_PUBLIC_LOCAL_MODE=true

# ── Supabase cloud (only needed when NEXT_PUBLIC_LOCAL_MODE=false) ──
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
